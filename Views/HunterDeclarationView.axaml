<UserControl xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:vm="using:Deer_o_matic.ViewModels"
    x:Class="Deer_o_matic.Views.HunterDeclarationView"
    x:DataType="vm:HunterDeclarationViewModel">

    <Grid RowDefinitions="Auto, Auto, *, Auto, Auto" x:Name="Root" Margin="8">

        <TextBlock Margin="8" Text="Hunt information:"/>

        <Rectangle Grid.Row="1" Height="1" Fill="Gray" HorizontalAlignment="Stretch"/>

        <TextBlock Grid.Row="2" Margin="8" >Data here </TextBlock>

        <Rectangle Grid.Row="3" Height="1" Fill="Gray" HorizontalAlignment="Stretch"/>
        
    </Grid>
</UserControl>