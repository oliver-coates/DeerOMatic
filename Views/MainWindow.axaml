<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:Deer_o_matic.ViewModels"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:views="clr-namespace:Deer_o_matic.Views"
        mc:Ignorable="d" d:DesignWidth="1902" d:DesignHeight="1080"
        x:Class="Deer_o_matic.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Icon="/Assets/Icons/icon1.ico"
        Title="Deer_o_matic"
        Width="1920"
        Height="1080">

    <Design.DataContext>
        <!-- This only sets the DataContext for the previewer in an IDE,
             to set the actual DataContext for runtime, set the DataContext property in code (look at App.axaml.cs) -->
        <vm:MainWindowViewModel/>
    </Design.DataContext>
    

    <DockPanel>
        <!-- HEADER -->
        <Grid RowDefinitions="Auto, Auto" Margin="8" DockPanel.Dock="Top">
            <TextBlock Grid.Row="0" Margin="8">Deer 'O Matic!</TextBlock>
            <Rectangle Grid.Row="1" Height="1" Fill="Gray" HorizontalAlignment="Stretch"/>
        </Grid>

        <!-- FOOTER (& Export Button) -->
        <Grid RowDefinitions="Auto, Auto" Margin="8" DockPanel.Dock="Bottom">
            <Rectangle Grid.Row="0" Height="1" Fill="Gray" HorizontalAlignment="Stretch"/>
            
            <Grid Grid.Row="1" Margin="8" ColumnDefinitions="Auto, Auto">
                <Button   Grid.Column="0"  Command="{Binding ExportCommand}" Margin= "0, 0, 8, 0"> Export </Button>
                <CheckBox Grid.Column="1" Content="Fillable?" IsChecked="{Binding ExportPdfFillable}"/>        
            </Grid>
        </Grid>

        <!-- Main Content -->
        <Grid ColumnDefinitions="Auto, *">

            <!-- Context Selection: -->
            <ListBox 
                Grid.Column="0"
                SelectedIndex="{Binding SelectedTabIndex}"
                Width="150">
                <ListBoxItem>Hunt Info</ListBoxItem>
                <ListBoxItem>Map View</ListBoxItem> 
            </ListBox>

            <!-- Content Display: -->
            <ContentControl
                Grid.Column="1"
                Content="{Binding SelectedContent}">
            </ContentControl>


            <!-- TAB 1 : Hunter Information & File Upload -->            
            <!-- <TabItem Header="Hunt Information">
                <Grid ColumnDefinitions="*,*">
                    <views:HunterDeclarationView Grid.Column="0" DataContext="{Binding HunterDeclaration}" />
                    <views:FileUploadView Grid.Column="1" DataContext="{Binding FileUpload}"/>
                </Grid>
            </TabItem> -->

            <!-- Tab 2 : Map View -->
            <!-- <TabItem Header="Map">
                <views:MapView Grid.Row="1" DataContext="{Binding HuntMap}"/>
            </TabItem> -->

        </Grid>
        
        
    </DockPanel>
</Window>

