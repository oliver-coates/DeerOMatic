<UserControl xmlns="https://github.com/avaloniaui"
            xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
            xmlns:vm="using:Deer_o_matic.ViewModels"
            xmlns:mapsui="clr-namespace:Mapsui.UI.Avalonia;assembly=Mapsui.UI.Avalonia"
            x:Class="Deer_o_matic.Views.MapView"
            x:DataType="vm:MapViewModel"
>
    <mapsui:MapControl Map="{Binding SimpleMap}" />
</UserControl>