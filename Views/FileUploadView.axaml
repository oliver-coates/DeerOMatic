<UserControl xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:vm="using:Deer_o_matic.ViewModels"
    x:Class="Deer_o_matic.Views.FileUploadView"
    x:DataType="vm:FileUploadViewModel">

    <Grid RowDefinitions="Auto, Auto, Auto, Auto, *" x:Name="Root" Margin="8">

        <!-- Title -->
        <TextBlock Grid.Row="0" Margin="8" Text="KML files:"/>
        <Rectangle Grid.Row="1" Height="1" Fill="Gray" HorizontalAlignment="Stretch"/>
        
        <!-- Buttons -->
        <Grid Grid.Row="2" ColumnDefinitions = "Auto, Auto" Margin="0, 8, 8, 8">
            <Button  Grid.Column="0" Command="{Binding OpenFileCommand}" Margin="0,0,8,0">Add New</Button>
            <Button  Grid.Column="1" Command="{Binding RemoveAllFlightData}" Margin="0,0,8,0">Clear</Button>
        </Grid>
        <Rectangle Grid.Row="3" Height="1" Fill="Gray" HorizontalAlignment="Stretch"/>

        <!-- File Scrollview -->
        <ScrollViewer Margin="8" Grid.Row="4">
            <ItemsControl ItemsSource="{Binding FlightData}" ItemTemplate="{StaticResource FlightDataTemplate}"/>    
        </ScrollViewer>
        
        
    </Grid>
</UserControl>