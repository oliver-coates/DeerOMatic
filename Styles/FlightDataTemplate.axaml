<ResourceDictionary xmlns="https://github.com/avaloniaui"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:vm="using:Deer_o_matic.ViewModels"
                    xmlns:models="clr-namespace:Deer_o_matic.Models">

    <DataTemplate DataType="vm:FlightDataViewModel"  x:Key="FlightDataTemplate">
        <Grid ColumnDefinitions="*, Auto" Margin="8">
            <StackPanel Grid.Column="0">
                <TextBlock Text="{Binding Name}"/>
                <TextBlock FontSize="10" Text="{Binding Path}" />        
            </StackPanel>    
            
            <!-- $parent[UserControl] walks up the visual tree until it finds a UserControl (Which will be the FileUploadViewModel) -->
            <Button Grid.Column="1" 
                    Command="{Binding $parent[UserControl].((vm:FileUploadViewModel)DataContext).RemoveFlightData}"
                    CommandParameter="{Binding .}">
                    Delete
            </Button>
        </Grid>    
    </DataTemplate>

</ResourceDictionary>
